<?xml version="1.0" encoding="utf-8"?>
<!--
  Per-row animation played when the widget's ListView is rebuilt
  after a tab switch. Each row slides in from the right (small
  offset) and fades in. RemoteViews doesn't support programmatic
  Animator objects, so we use an XML layoutAnimation which the
  framework applies automatically the next time the list is
  drawn after notifyAppWidgetViewDataChanged().
-->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:duration="260"
    android:interpolator="@android:interpolator/decelerate_quad"
    android:shareInterpolator="true">

    <translate
        android:fromXDelta="12%"
        android:toXDelta="0%" />

    <alpha
        android:fromAlpha="0.0"
        android:toAlpha="1.0" />
</set>
