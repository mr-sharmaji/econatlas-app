<?xml version="1.0" encoding="utf-8"?>
<!-- Selected-state pill background: filled accentBlue with a
     slightly stronger border. Swapped in by the Kotlin provider
     via setInt(..., "setBackgroundResource", ...) when the tab is
     the active one. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="12dp" />
    <solid android:color="#3B82F6" />
    <stroke
        android:width="0.5dp"
        android:color="#FFFFFF" />
</shape>
